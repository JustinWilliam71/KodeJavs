<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.rplbo.app.ug8.Controller.LoginController">
    <children>
        <Label alignment="CENTER" contentDisplay="CENTER" layoutX="171.0" layoutY="36.0" prefHeight="35.0" prefWidth="258.0" text="UMBRELLA SECURE TERMINAL">
            <font>
                <Font name="System Bold" size="16.0" />
            </font>
        </Label>
        <GridPane layoutX="70.0" layoutY="86.0" prefHeight="172.0" prefWidth="449.0">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            </rowConstraints>
            <children>
                <Label prefHeight="32.0" prefWidth="222.0" text="OPERATIVE ID:" />
                <TextField fx:id="txtUsername" prefHeight="26.0" prefWidth="280.0" GridPane.rowIndex="1" />
                <Label prefHeight="34.0" prefWidth="217.0" text="PASSCODE:" GridPane.rowIndex="2" />
                <PasswordField fx:id="txtPassword" GridPane.rowIndex="3" />
            </children>
        </GridPane>

        <!-- Penambahan onAction agar tombol berfungsi -->
        <Button fx:id="btnLogin" layoutX="68.0" layoutY="285.0" mnemonicParsing="false" onAction="#handleLogin" prefHeight="35.0" prefWidth="450.0" text="AUTHENTICATE" />

        <!-- Penambahan Label Status untuk menampilkan pesan error -->
        <Label fx:id="lblStatus" alignment="CENTER" layoutX="70.0" layoutY="335.0" prefHeight="17.0" prefWidth="449.0" textAlignment="CENTER">
            <font>
                <Font name="System Bold" size="12.0" />
            </font>
        </Label>
    </children>
</AnchorPane>
